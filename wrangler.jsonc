{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "flowpilot-saas-landing-live",
  "compatibility_date": "2026-06-26",
  "workers_dev": true,
  "routes": [
    {
      "pattern": "siteuret.com/flowpilot*",
      "zone_name": "siteuret.com"
    }
  ],
  "assets": {
    "directory": "./out"
  }
}
